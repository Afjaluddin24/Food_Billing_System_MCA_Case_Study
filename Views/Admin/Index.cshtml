
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="col-md-12 m-auto">
    <div class="card">
        <div class="card-header bg-transparent">
            <div class="col-md-6 text-start">Dashboard</div>
        </div>
        <div class="card-body">
            <div class="col-md-12">
                <div class="row">
                    <div class="col-md-4">
                        <div class="card bg-info text-center text-white shadow">
                            <div class="card-body">
                                <h5>Category</h5>
                                <b id="Category"></b>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card bg-success text-center text-white shadow">
                            <div class="card-body">
                                <h5>Food</h5>
                                <b id="Food"></b>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card bg-danger text-center text-white shadow">
                            <div class="card-body">
                                <h5>Order</h5>
                                <b id="Order"></b>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4 mt-3 mb-2">
                        <div class="card bg-primary text-center text-white shadow">
                            <div class="card-body">
                                <h5>Sales</h5>
                                <b id="Sales"></b>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function(){
        $.ajax({
            url:"http://172.29.30.121:999/api/Dashboard/Dashboard",
            method:"get",
            success:function(res){
                const data = res.result;
                console.log("Data is",data);
                $("#Category").html(data.category);
                $("#Food").html(data.foodMenu);
                $("#Order").html(data.order);
                $("#Sales").html(data.totalSale);
            },
            error:function(err){
                console.log(err);
            }
        })
    })
</script>